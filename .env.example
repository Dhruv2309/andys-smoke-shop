# ── Backend ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
SUCCESS_URL=https://your-store.example.com/success
CANCEL_URL=https://your-store.example.com/cancel
PORT=3000

# PostgreSQL connection string (required for auth + cart + orders)
# Local example:  postgresql://postgres:password@localhost:5432/andys
# Render/Railway: copy from your dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/andys

# Secret used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret

# Stripe Identity webhook secret (get from Stripe Dashboard → Webhooks after deployment)
# Events to enable: identity.verification_session.verified, identity.verification_session.requires_input
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Public URL of your frontend app (used as return_url after Stripe Identity verification)
APP_URL=https://Dhruv2309.github.io/andys-smoke-shop

# ── Frontend (set as GitHub Secret named BACKEND_URL) ──────────────────────
# Baked into the web build at CI time. Defaults to localhost:3000 locally.
REACT_APP_API_URL=https://your-backend.example.com
